              <circle
                cx="12"
                cy="12"
                r="10"
              />
            </svg>
          </span>
        </button>
        <div
          class="mt-0.5 shrink-0"
        >
          <div
            class="w-4 h-4 rounded-none border-2 flex items-center justify-center transition-colors border-primary"
          >
            <div
              class="w-2 h-2 rounded-none bg-primary"
            />
          </div>
        </div>
        <div
          class="flex-1 min-w-0"
        >
          <div
            class="flex flex-col"
          >
            <span
              class="text-sm font-medium leading-none text-foreground"
            >
              Deliver to
            </span>
            <p
              class="text-xs font-normal leading-4 tracking-[0.12px] text-muted-foreground mt-0.5"
            >
              Enter ZIP code to see delivery estimate
            </p>
          </div>
        </div>
      </label>
      <label
        class="text-sm leading-none font-medium select-none group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50 peer-disabled:cursor-not-allowed peer-disabled:opacity-50 flex items-start gap-2 p-3 rounded-none border transition-colors text-left shadow-xs cursor-pointer border-muted-foreground/20 hover:border-primary/50"
        data-slot="label"
