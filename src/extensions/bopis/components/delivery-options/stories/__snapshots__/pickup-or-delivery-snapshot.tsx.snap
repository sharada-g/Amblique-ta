          data-radix-collection-item=""
          data-slot="radio-group-item"
          data-state="unchecked"
          id="pickup-option"
          role="radio"
          tabindex="-1"
          type="button"
          value="pickup"
        />
        <div
          class="mt-0.5 shrink-0"
        >
          <div
            class="w-4 h-4 rounded-none border-2 flex items-center justify-center transition-colors border-muted-foreground/20"
          />
        </div>
        <div
