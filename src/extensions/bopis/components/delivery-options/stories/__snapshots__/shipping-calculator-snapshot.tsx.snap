// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ShippingCalculator stories snapshot > Default story renders and matches snapshot 1`] = `
<div>
  <div
    class="p-4 border border-muted-foreground/20 rounded-none bg-card"
  >
    <div
      class="space-y-3"
    >
      <div>
        <label
          class="text-sm font-medium text-foreground"
          for="delivery-zip-input"
        >
          Calculate Shipping
        </label>
      </div>
      <div
        class="flex gap-2"
      >
        <div
          class="flex-1"
        >
          <input
            aria-describedby="delivery-message"
            aria-invalid="false"
            aria-label="ZIP code"
            class="w-full px-3 py-2 text-sm border rounded-none transition-colors focus:outline-none focus:ring-2 bg-background border-muted-foreground/20 focus:border-ring focus:ring-ring"
            id="delivery-zip-input"
            inputmode="numeric"
            maxlength="5"
            placeholder="Enter ZIP code"
            type="text"
            value=""
          />
        </div>
        <button
          aria-label="Calculate delivery estimate"
          class="px-4 py-2 text-sm font-medium rounded-none transition-colors whitespace-nowrap bg-primary text-primary-foreground hover:bg-primary/90 disabled:bg-muted disabled:text-muted-foreground disabled:cursor-not-allowed"
          type="button"
        >
          Calculate
        </button>
      </div>
      <p
        class="text-xs text-muted-foreground"
        id="delivery-message"
      >
        Enter a 5-digit ZIP code to see delivery estimates.
      </p>
    </div>
  </div>
</div>
`;

