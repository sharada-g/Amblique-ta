      data-slot="card"
      data-testid="sf-toggle-card-shipping-options"
    >
      <div
        class="@container/card-header grid auto-rows-min gap-2 px-6 has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6 grid-rows-1 items-center border-b border-border pb-4"
        data-slot="card-header"
      >
        <div
          class="text-base font-semibold text-foreground"
