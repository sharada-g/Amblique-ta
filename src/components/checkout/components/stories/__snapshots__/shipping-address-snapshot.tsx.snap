exports[`ShippingAddress stories snapshot > SummaryView story renders and matches snapshot 1`] = `
<div
  class="max-w-2xl mx-auto p-6"
>
  <div>
    <div
      class="bg-card text-card-foreground flex flex-col border relative rounded-none py-4 shadow-none gap-4"
      data-slot="card"
      data-testid="sf-toggle-card-shipping-address"
    >
      <div
        class="@container/card-header grid auto-rows-min gap-2 px-6 has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6 grid-rows-1 items-center border-b border-border pb-4"
        data-slot="card-header"
      >
        <div
          class="text-base font-semibold text-foreground"
          data-slot="card-title"
          tabindex="0"
        >
          <span
            class="text-2xl font-bold tracking-tight text-card-foreground"
          >
            Shipping Address
          </span>
        </div>
        <div
          class="col-start-2 row-start-1 justify-self-end row-span-1 self-center"
          data-slot="card-action"
        >
          <button
            aria-label="Edit"
            class="inline-flex items-center justify-center whitespace-nowrap text-sm transition-all disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4 shrink-0 [&_svg]:shrink-0 outline-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 aria-invalid:border-destructive text-primary underline-offset-4 hover:underline h-8 rounded-md gap-1.5 px-3 has-[>svg]:px-2.5 font-bold"
            data-size="sm"
            data-slot="button"
            data-variant="link"
            type="button"
          >
            Edit
          </button>
        </div>
      </div>
      <div
        class="px-6"
        data-slot="card-content"
        data-testid="sf-toggle-card-shipping-address-content"
      >
        <p
          class="text-sm text-muted-foreground"
        >
          Complete previous steps to continue
        </p>
      </div>
    </div>
  </div>
</div>
`;

