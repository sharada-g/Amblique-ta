                              d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"
                            />
                            <circle
                              cx="12"
                              cy="12"
                              r="3"
                            />
                          </svg>
                        </button>
                      </div>
                      <p
                        class="text-destructive text-sm"
                        data-slot="form-message"
                        id="_r_i_-form-item-message"
                      >
                        Please enter a valid CVV
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div
              class="space-y-4"
            >
              <div
                class="border-t border-input pt-4 space-y-4"
              >
                <div
                  class="grid gap-2 space-y-0"
                  data-slot="form-item"
                >
                  <label
                    class="flex cursor-pointer items-start gap-3"
                    for="useDifferentBilling"
                  >
                    <button
                      aria-checked="false"
                      aria-describedby="_r_k_-form-item-description"
                      aria-invalid="false"
                      aria-label="Use a different billing address"
                      class="peer border-input data-[state=checked]:bg-primary data-[state=checked]:text-primary-foreground data-[state=checked]:border-primary focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 aria-invalid:border-destructive size-4 shrink-0 rounded-[4px] border shadow-xs transition-shadow outline-none focus-visible:ring-[3px] disabled:cursor-not-allowed disabled:opacity-50"
                      data-slot="form-control"
                      data-state="unchecked"
                      id="useDifferentBilling"
                      role="checkbox"
                      type="button"
                      value="on"
                    />
                    <input
                      aria-hidden="true"
                      style="position: absolute; pointer-events: none; opacity: 0; margin: 0px; transform: translateX(-100%); width: 0px; height: 0px;"
                      tabindex="-1"
                      type="checkbox"
                      value="on"
                    />
                    <span
                      class="text-sm font-normal leading-none text-foreground pt-0.5"
                    >
                      Use a different billing address
                    </span>
                  </label>
                </div>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
`;
