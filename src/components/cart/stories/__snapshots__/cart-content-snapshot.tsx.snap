exports[`CartContent stories snapshot > MobileLayout story renders and matches snapshot 1`] = `
<div
  class="flex-1 min-h-screen bg-background mb-10"
  data-testid="sf-cart-container"
>
  <div
    class="section-container"
  >
    <nav
      aria-label="breadcrumb"
      class="mb-6 mt-4"
      data-slot="breadcrumb"
    >
      <ol
        class="text-muted-foreground flex flex-wrap items-center gap-1.5 text-sm break-words sm:gap-2.5"
        data-slot="breadcrumb-list"
      >
        <li
          class="inline-flex items-center gap-1.5"
          data-slot="breadcrumb-item"
        >
          <a
            class="hover:text-foreground transition-colors"
            data-slot="breadcrumb-link"
            href="/"
          >
            Home
          </a>
        </li>
        <li
          aria-hidden="true"
          class="[&>svg]:size-3.5"
          data-slot="breadcrumb-separator"
          role="presentation"
        >
          <svg
            aria-hidden="true"
            class="lucide lucide-chevron-right"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="m9 18 6-6-6-6"
            />
          </svg>
        </li>
        <li
          class="inline-flex items-center gap-1.5"
          data-slot="breadcrumb-item"
        >
          <span
            aria-current="page"
            aria-disabled="true"
            class="text-foreground font-normal"
            data-slot="breadcrumb-page"
            role="link"
          >
            Cart
          </span>
        </li>
      </ol>
    </nav>
    <div
      class="space-y-3"
    >
      <div
        class="bg-card text-card-foreground flex flex-col gap-6 border py-6 !py-4 rounded-none shadow-none"
        data-slot="card"
      >
        <div
          class="px-[var(--cart-summary-px)]"
          data-slot="card-content"
        >
          <div
            class="space-y-4"
            data-testid="sf-order-summary"
          >
            <h2
              class="text-left text-lg font-semibold leading-[120%] tracking-[-0.45px] text-card-foreground"
              id="order-summary-heading-desktop"
            >
              Order Summary
            </h2>
            <hr
              class="mx-[calc(var(--cart-summary-px)*-1)] border-border"
            />
            <div
              aria-label="Order Summary"
              class="space-y-2"
              role="region"
            >
              <div
                class="space-y-2 text-sm font-normal leading-5 text-muted-foreground pb-2"
              >
                <div
                  class="flex justify-between items-center"
                >
                  <span>
                    Subtotal
                  </span>
                  <span>
                    $148.00
                  </span>
                </div>
                <div
                  class="flex justify-between items-center"
                >
                  <div
                    class="flex items-center"
                  >
                    <span>
                      Shipping
                    </span>
                  </div>
                  <span
                    class="text-primary font-medium"
                  >
                    FREE
                  </span>
                </div>
                <div
                  class="flex justify-between items-center text-sm font-bold leading-5 text-muted-foreground"
                >
                  <span>
                    Estimated Total
                  </span>
                  <span>
                    $159.84
                  </span>
                </div>
              </div>
              <hr
                class="mx-[calc(var(--cart-summary-px)*-1)] border-border"
              />
              <div
                class="flex w-full flex-col gap-2 pt-2 pb-4"
              >
                <div
                  class="mb-0"
                  data-orientation="vertical"
                  data-slot="accordion"
                >
                  <div
                    class="border-b last:border-b-0"
                    data-orientation="vertical"
                    data-slot="accordion-item"
                    data-state="open"
                  >
                    <h3
                      class="flex"
                      data-orientation="vertical"
                      data-state="open"
                    >
                      <button
                        aria-controls="radix-_r_1e_"
                        aria-expanded="true"
                        class="focus-visible:border-ring focus-visible:ring-ring/50 flex flex-1 items-start rounded-md py-4 text-left text-sm font-medium transition-all outline-none hover:underline focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 [&[data-state=open]>svg]:rotate-180 justify-start gap-2 pt-1 pb-0 [&>svg]:text-primary"
                        data-orientation="vertical"
                        data-radix-collection-item=""
                        data-slot="accordion-trigger"
                        data-state="open"
                        id="radix-_r_1d_"
                        type="button"
                      >
                        <span
                          class="text-left text-sm font-medium leading-5 text-card-foreground"
                        >
                          Enter a Promotion Code
                        </span>
                        <svg
                          aria-hidden="true"
                          class="lucide lucide-chevron-down text-muted-foreground pointer-events-none size-4 shrink-0 translate-y-0.5 transition-transform duration-200"
                          fill="none"
                          height="24"
                          stroke="currentColor"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          viewBox="0 0 24 24"
                          width="24"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <path
                            d="m6 9 6 6 6-6"
                          />
                        </svg>
                      </button>
                    </h3>
