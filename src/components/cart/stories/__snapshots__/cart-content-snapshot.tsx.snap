exports[`CartContent stories snapshot > CartWithPickupDelivery story renders and matches snapshot 1`] = `
<div
  class="flex-1 min-h-screen bg-background mb-10"
  data-testid="sf-cart-container"
>
  <div
    class="section-container"
  >
    <nav
      aria-label="breadcrumb"
      class="mb-6 mt-4"
      data-slot="breadcrumb"
    >
      <ol
        class="text-muted-foreground flex flex-wrap items-center gap-1.5 text-sm break-words sm:gap-2.5"
        data-slot="breadcrumb-list"
      >
        <li
          class="inline-flex items-center gap-1.5"
          data-slot="breadcrumb-item"
        >
          <a
            class="hover:text-foreground transition-colors"
            data-slot="breadcrumb-link"
            href="/"
          >
            Home
          </a>
        </li>
        <li
          aria-hidden="true"
          class="[&>svg]:size-3.5"
          data-slot="breadcrumb-separator"
          role="presentation"
        >
          <svg
            aria-hidden="true"
            class="lucide lucide-chevron-right"
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="m9 18 6-6-6-6"
            />
          </svg>
        </li>
        <li
          class="inline-flex items-center gap-1.5"
          data-slot="breadcrumb-item"
        >
          <span
            aria-current="page"
            aria-disabled="true"
            class="text-foreground font-normal"
            data-slot="breadcrumb-page"
            role="link"
          >
            Cart
          </span>
        </li>
      </ol>
    </nav>
    <div
      class="grid grid-cols-1 lg:grid-cols-[66%_1fr] lg:gap-11"
    >
      <div
        class="md:order-2 lg:order-1 space-y-3"
      >
        <div
          class="md:p-8 p-3 border border-border rounded-none"
        >
          <div
            class="flex items-start justify-between gap-2 mb-4"
          >
            <div
              class="flex items-start gap-2"
            >
              <svg
                aria-hidden="true"
                class="lucide lucide-map-pin size-5 text-muted-foreground flex-shrink-0 mt-0.5"
                fill="none"
                height="24"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
