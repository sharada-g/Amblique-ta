{
    "compilerOptions": {
        // CommonJS module: CodeceptJS page objects require `export =` for inject() compatibility.
        // ESNext forbids `export =`, so CommonJS is used here. CLI scripts run via tsx regardless.
        "module": "CommonJS",
        "target": "ES2022",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "types": ["codeceptjs", "@playwright/test", "node", "mocha", "chai"],
        "allowJs": false
    },
    "include": ["src/**/*", "helpers/**/*.ts", "types/**/*", "steps.d.ts", "utils/**/*", "vitest.config.ts"],
    "exclude": ["node_modules", "**/*.cjs", "codecept.conf.cjs"]
}
