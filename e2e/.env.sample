# Environment variables for storefront-next-e2e
# Copy this file to .env and customize for your environment
# .env is gitignored - developers and CI maintain their own
#
# This file configures the CodeceptJS test runner only. Storefront app
# configuration (SCAPI creds, MRT_PROJECT, etc.) lives in ../.env.default.

# ============================================
# E2E Test Target Configuration
# ============================================
# Note: Actual storefront configuration is in the parent directory (..)
# These settings tell CodeceptJS where to run tests and which site to target

# Base URL where the storefront is running (optional)
# Can be overridden by --mode flag (e.g., --mode local, --mode remote)
# So if BASE_URL=https://your-storefront.example.com but you run the tests with
# --mode=local, the flag takes priority and targets localhost.
#
# Local: http://localhost:5173
# Remote: https://your-storefront.example.com
BASE_URL=http://localhost:5173

# Commerce Cloud Site ID to target for testing
SITE_ID=RefArchGlobal

# URL prefix (optional)
# When set, URLs are prefixed: /{SITE_ALIAS}/{LOCALE}/{path}
SITE_ALIAS=global
LOCALE=en-GB

# ============================================
# Test User Configuration
# ============================================

# Pre-existing E2E test user credentials
# This user should have existing orders for testing Order History page.
# IMPORTANT: Set the actual password in your local process.env file (gitignored)
E2E_TEST_USER_EMAIL=e2e.test.user@gmail.com
E2E_TEST_USER_PASSWORD=

# ============================================
# Local Development Server
# ============================================

# Port for local dev server
STOREFRONT_DEV_PORT=5173

# Path to storefront app (relative to e2e package)
STOREFRONT_APP_PATH=..

# ============================================
# Test Execution Settings
# ============================================

# Run browser in headless mode (true for CI, false for local dev)
HEADLESS=false

# Enable verbose output
VERBOSE=false
WORKERS=1

# ============================================
# Browser Settings
# ============================================

# Browser window size (WIDTHxHEIGHT)
WINDOW_SIZE=1200x900

# ============================================
# Timeout Settings (milliseconds)
# ============================================

# Maximum time to wait for elements
WAIT_FOR_TIMEOUT=15000

# Delay between actions
WAIT_FOR_ACTION=1000

# ============================================
# CI/CD Settings
# ============================================

# Running in CI environment
CI=false

# AI features (--ai flag): see e2e/CLAUDE.md "AI Environment Setup" for required vars
